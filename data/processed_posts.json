import json
import pandas as pd


class FewShotPosts:
    def __init__(self, file_path="data/processed_posts.json"):
        self.df = None
        self.unique_tags = None
        self.load_posts(file_path)

    def clean_text(self, text):
        """Remove invalid Unicode characters safely."""
        if isinstance(text, str):
            return text.encode("utf-8", errors="ignore").decode("utf-8")
        return text

    def load_posts(self, file_path):
        with open(file_path, "r", encoding="utf-8") as f:
            posts = json.load(f)

        # Clean every text field
        for post in posts:
            if "text" in post:
                post["text"] = self.clean_text(post["text"])

        # Create DataFrame
        self.df = pd.DataFrame.from_records(posts)

        # Create length column
        self.df["length"] = self.df["line_count"].apply(self.categorize_length)

        # Collect unique tags
        all_tags = []
        for tags in self.df["tags"]:
            all_tags.extend(tags)

        self.unique_tags = sorted(set(all_tags))

    def get_filtered_posts(self, length, language, tag):
        df_filtered = self.df[
            (self.df["language"] == language)
            & (self.df["length"] == length)
            & (self.df["tags"].apply(lambda x: tag in x))
        ]

        return df_filtered.to_dict(orient="records")

    def categorize_length(self, line_count):
        if line_count < 5:
            return "Short"
        elif line_count <= 10:
            return "Medium"
        else:
            return "Long"

    def get_tags(self):
        return self.unique_tags


if __name__ == "__main__":
    fs = FewShotPosts()
    print(fs.get_filtered_posts("Medium", "Hinglish", "Job Search"))